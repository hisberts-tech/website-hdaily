# Postgres connection string.
# Local docker-compose default:
DATABASE_URL="postgresql://hdaily:hdaily@localhost:5432/hdaily?schema=public"

# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (the Vite dev server)
CORS_ORIGIN="http://localhost:3000"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Manual MonCash: the merchant number customers send payments to.
MONCASH_NUMBER="+509 3913 4651"
